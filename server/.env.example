# Aaron Jersey World — Server Environment Variables

# Server
PORT=5000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Frontend URL (for CORS) — comma-separated for multiple domains
CLIENT_URL=http://localhost:5173

# JWT Authentication
JWT_ACCESS_SECRET=change-this-to-a-long-random-access-secret
JWT_REFRESH_SECRET=change-this-to-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional — notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=admin@aaronjerseyworld.com
ADMIN_INITIAL_PASSWORD=change-this-secure-password

# WhatsApp (default business number)
WHATSAPP_NUMBER=256781161690
